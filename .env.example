# Webserver Port (Cloud Run setzt das automatisch)
PORT=8080

# Auth Invite Code (für Erstanmeldung neuer Mitarbeiter)
invite_code=85fce0c7af4544e48b97630d337f0141

# Firestore / Google Cloud
# In Cloud Run werden Application Default Credentials automatisch erkannt.
# Lokal: GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# Microsoft Graph API — OAuth Delegated Flow für Email-Versand
# Azure App-Registrierung benötigt:
#   - Permission: Mail.Send (Delegated)
#   - Redirect URI: https://DEINE-CLOUD-RUN-URL/api/email/callback
M365_TENANT_ID=deine-tenant-id
M365_CLIENT_ID=deine-client-id
M365_CLIENT_SECRET=dein-client-secret
M365_REDIRECT_URI=https://DEINE-CLOUD-RUN-URL/api/email/callback
