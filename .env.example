# Webserver Port (Cloud Run setzt das automatisch)
PORT=8080

# ============================================
# AUTH & SICHERHEIT
# ============================================

# Invite-Code für Erstanmeldung neuer Mitarbeiter
# PFLICHT: Ohne diesen Code kann sich niemand erstmalig registrieren
INVITE_CODE=85fce0c7af4544e48b97630d337f0141

# Seed-Passwort für den ersten Admin-User (Thomas Kedzierski)
# OPTIONAL: Wenn nicht gesetzt, wird Thomas ohne Passwort angelegt
#           und muss sich über Erstanmeldung + Invite-Code registrieren
SEED_PASSWORD=dein-sicheres-passwort

# JWT Secret für API-Authentifizierung
# PFLICHT: Zufälliger String, mindestens 32 Zeichen
# Generieren mit: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=dein-zufaelliger-geheimer-string

# Cron-Secret für automatische Backups (Cloud Scheduler)
# OPTIONAL: Wenn gesetzt, muss Cloud Scheduler diesen Wert als x-cron-secret Header senden
CRON_SECRET=dein-cron-secret

# Frontend-URL für CORS (nur diese Domain darf API-Requests senden)
FRONTEND_URL=https://zeiterfassung-frontend.pages.dev

# ============================================
# FIRESTORE / GOOGLE CLOUD
# ============================================
# In Cloud Run werden Application Default Credentials automatisch erkannt.
# Lokal: GOOGLE_APPLICATION_CREDENTIALS=./service-account.json

# ============================================
# MICROSOFT GRAPH API (Email-Versand)
# ============================================
# Azure App-Registrierung benötigt:
#   - Permission: Mail.ReadWrite (Delegated) — für Entwürfe
#   - Redirect URI: https://DEINE-CLOUD-RUN-URL/api/email/callback
#   - Platform: Web (NICHT Single Page Application!)
M365_TENANT_ID=deine-tenant-id
M365_CLIENT_ID=deine-client-id
M365_CLIENT_SECRET=dein-client-secret
M365_REDIRECT_URI=https://DEINE-CLOUD-RUN-URL/api/email/callback
